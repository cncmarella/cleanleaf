# Copy to .env and adjust for local development.
# The API reads plain environment variables, so load this with `set -a; source .env; set +a`
# or your shell tool of choice. .env is gitignored; .env.example is not.

# development | production
APP_ENV=development
PORT=8080

# Comma-separated list of origins allowed to call the API from a browser.
ALLOWED_ORIGINS=http://localhost:3000

# Leave RESEND_API_KEY empty in dev: the server falls back to the console
# mailer and logs enquiries instead of emailing them.
# Required when APP_ENV=production -- the server refuses to boot without it.
RESEND_API_KEY=

# Until a domain is verified in Resend, only onboarding@resend.dev may send.
MAIL_FROM=CleanLeaf Website <onboarding@resend.dev>
MAIL_TO=cleanleaf789@gmail.com
